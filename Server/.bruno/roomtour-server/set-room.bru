meta {
  name: POST set-room
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/v1/room
  body: json
  auth: none
}

body:json {
  {
    "room": "livingroom",
    "sessionId": "{{sessionId}}"
  }
}

script:post-response {
  if (res.status === 200 && res.body.sessionId) {
    bru.setVar("sessionId", res.body.sessionId);
  }
}
